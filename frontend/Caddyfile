http://{$DOMAIN:localhost}:8080 {
    encode gzip

    handle /api/* {
        reverse_proxy {$BACKEND_URL:backend}:{$BACKEND_PORT:8080}
    }

    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }

    header /assets/* Cache-Control "public, max-age=31536000, immutable"
}
