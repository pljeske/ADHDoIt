# Database
DATABASE_URL=postgres://adhdo:secret@db:5432/adhdo?sslmode=disable
DB_PASSWORD=secret

# Auth
JWT_SECRET=change-me-32-chars-minimum-secret!
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Server
PORT=8080
ENVIRONMENT=production
DOMAIN=localhost
BACKEND_URL=backend
BACKEND_PORT=8080

# SMTP (for email reminders)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=
SMTP_FROM='ADHDoIt <noreply@example.com>'

# Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# GitHub OAuth2 (optional — set all three to enable "Sign in with GitHub")
# 1. GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
# 2. Set Authorization callback URL to:
#    https://<your-domain>/api/v1/auth/github/callback
#    For local dev: http://localhost:8080/api/v1/auth/github/callback
# 3. Copy the Client ID and Client Secret below.
# For SSO across multiple apps: register each app as a separate OAuth App
# (or add multiple callback URLs to a single GitHub OAuth App).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8080/api/v1/auth/github/callback
# Comma-separated emails that are always granted admin on registration or first OAuth login.
# The first user to sign up via any method is also automatically made admin.
ADMIN_EMAILS=''
# URL the backend redirects to after a successful OAuth callback.
# Dev without docker compose: http://localhost:5173  |  Prod & local docker compose setup: leave empty (same origin via Caddy)
FRONTEND_URL=''

# Frontend (build-time, injected by Vite)
# Leave empty or set to /api/v1 when running with Docker (Caddy proxies /api/* to the backend).
# For local dev with the Vite dev server only, this is ignored — the Vite proxy handles it.
VITE_API_BASE_URL=/api/v1
VITE_VAPID_PUBLIC_KEY=
